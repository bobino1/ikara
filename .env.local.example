# Skopíruj do .env.local a doplň hodnoty.

# --- Sanity CMS (správa kurzov klientom) ---
# Kým nie je nastavené, web číta kurzy z data/courses.json (fallback).
NEXT_PUBLIC_SANITY_PROJECT_ID=tvoj_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# --- E-mail notifikácie (odoslanie prihlášky/kontaktu) ---
# API kľúč zo https://resend.com (zadarmo). Kým nie je nastavený, formuláre
# sa len zalogujú na server (neodošle sa e-mail).
RESEND_API_KEY=re_xxxxxxxx
# Kam majú chodiť prihlášky a správy (default: e-mail autoškoly).
CONTACT_EMAIL=jozefdanadai@autoskola-ikara.sk
# Odosielateľ. Bez vlastnej overenej domény nechaj onboarding@resend.dev.
RESEND_FROM=Autoškola IKARA <onboarding@resend.dev>
